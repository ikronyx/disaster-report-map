generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Incident {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type               String   @db.VarChar(50)
  description        String
  latitude           Float
  longitude          Float
  verification_score Int      @default(10)
  status             String   @default("active") @db.VarChar(20)
  area_name          String?  @db.VarChar(255)
  source             String   @default("citizen") @db.VarChar(50)
  created_at         DateTime @default(now()) @db.Timestamp(6)
  updated_at         DateTime @default(now()) @db.Timestamp(6)

  @@index([created_at], map: "idx_incidents_created_at")
  @@index([status], map: "idx_incidents_status")
  @@index([type], map: "idx_incidents_type")

   @@map("incidents")
}
